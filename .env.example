# ═══════════════════════════════════════════════════════════════════════════════
# CAMERAS CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════
#
# MULTI-CAMERA SETUP (recommended):
#   Set CAMERAS as a comma-separated list of camera IDs, then configure each
#   camera with its own RTSP_URL (and optionally HLS_URL, NAME).
#
#   Example - 2 cameras (cam01 and cam02):
#   CAMERAS=cam01,cam02
#   CAM01_RTSP_URL=rtsp://admin:password@192.168.1.100:554/stream
#   CAM01_NAME="Front Door"
#   CAM02_RTSP_URL=rtsp://admin:password@192.168.1.101:554/stream
#   CAM02_NAME="Backyard"
#
#   External HLS URL (optional, if you have an existing HLS stream):
#   CAM01_HLS_URL=https://your-hls-server.com/cam01/live.m3u8
#
# SINGLE CAMERA (legacy/default):
#   Use the simple variables below without CAMERAS set.
#
# ═══════════════════════════════════════════════════════════════════════════════

# ── Single camera (legacy/default) ─────────────────────────────────────────────
RTSP_URL=rtsp://admin:password@your-camera:554/stream

# ── Multi-camera: uncomment and configure above ─────────────────────────────────
# CAMERAS=cam01,cam02
# CAM01_RTSP_URL=rtsp://admin:password@192.168.1.100:554/stream
# CAM01_NAME="Front Door"
# CAM02_RTSP_URL=rtsp://admin:password@192.168.1.101:554/stream
# CAM02_NAME="Backyard"

# ── External HLS URL (for single camera or per-camera with CAMERAS) ──────────────
# HLS_URL=https://your-hls-server.com/live.m3u8
# Or per camera: CAM01_HLS_URL=https://your-hls-server.com/cam01/live.m3u8

# ── Web server ─────────────────────────────────────────────────────────────────
PORT=3777

# ── Segment storage ────────────────────────────────────────────────────────────
# Relative to where docker-compose.yml lives
SEGMENTS_DIR=./segments

# ── FFmpeg segment rotation (seconds) ─────────────────────────────────────────
SEGMENT_TIME=300

# ── otslog stamp follow interval (seconds) ─────────────────────────────────────
FOLLOW_INTERVAL=1

# ── otslog idle timeout (seconds, stops following when file hasn't grown) ─────
IDLE_TIMEOUT=40

# ── Stamp aggregators (comma-separated list of calendar URLs) ───────────────────
# Each digest is submitted to all listed aggregators in parallel.
# You can add any OpenTimestamps-compatible calendar server.
#
# Public calendars:
#   https://alice.btc.calendar.opentimestamps.org/digest
#   https://bob.btc.calendar.opentimestamps.org/digest
#   https://oe1.assortedm.eu/digest
#   https://ots.alt.ku derringer.net/digest
#
# To disable stamping entirely, set STAMP_AGGREGATORS to empty string (not recommended).
STAMP_AGGREGATORS=https://alice.btc.calendar.opentimestamps.org/digest,https://bob.btc.calendar.opentimestamps.org/digest
