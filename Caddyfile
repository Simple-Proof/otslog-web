rtsp.simpleproof.xyz {
    reverse_proxy otslog-web:3777

    # WebSocket support (for /ws/stamp)
    @websocket {
        header Connection *Upgrade*
        header Upgrade websocket
    }
    reverse_proxy @websocket otslog-web:3777

    encode gzip

    log {
        output file /var/log/caddy/access.log
        format json
    }
}
